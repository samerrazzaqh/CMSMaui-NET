<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:icon="clr-namespace:CMSBlazor.Client.Utilities"
             x:Class="CMSBlazor.Client.Views.Home.SinglePost">

    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="{AppThemeBinding Dark='#212121',Light='#F5F5F5'}"
                                   StatusBarStyle="Default" />
    </ContentPage.Behaviors>

    <NavigationPage.TitleView>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label x:Name="lbTitle" Grid.Column="0" FontSize="18" VerticalOptions="Center" HorizontalOptions="Start"></Label>

            <StackLayout Grid.Column="1" HorizontalOptions="EndAndExpand" Orientation="Horizontal" Margin="0,5,5,5">
                <Button HorizontalOptions="End" Clicked="BtnClose_OnClicked" Text="{x:Static icon:IconFont.Close}"
                        Style="{x:StaticResource GoogleFont }" TextColor="#776CE6" BackgroundColor="Transparent"
                        BorderWidth="1" BorderColor="Transparent" x:Name="btnClose" />
            </StackLayout>
        </Grid>
    </NavigationPage.TitleView>

    <!-- ======================== -->


    <ScrollView>
        <Grid RowDefinitions="auto,auto,auto">
            <ScrollView Grid.Row="0" HeightRequest="{OnPlatform MacCatalyst='510', iOS='310',Android='310'}" Margin="10" HorizontalOptions="Center" VerticalOptions="Center" Orientation="Horizontal" HorizontalScrollBarVisibility="Always">
                <Grid ColumnDefinitions="{OnPlatform MacCatalyst='500,500', iOS='300,300',Android='300,300'}">
                    <Frame Grid.Column="0" BorderColor="Gray" HeightRequest="{OnPlatform MacCatalyst='500', iOS='300',Android='300'}" VerticalOptions="Start" HasShadow="True"
                           CornerRadius="20" Padding="0" Margin="10" IsClippedToBounds="True">
                        <Image x:Name="imgPost" Aspect="AspectFill"></Image>
                    </Frame>
                    <Frame Grid.Column="1" BorderColor="Gray" HeightRequest="{OnPlatform MacCatalyst='500', iOS='300',Android='300'}" VerticalOptions="Start" HasShadow="True"
                           CornerRadius="20" Padding="0" Margin="10" IsClippedToBounds="True">
                        <WebView x:Name="linkVideo" />
                    </Frame>
                </Grid>
            </ScrollView>
            <BoxView Grid.Row="1" HorizontalOptions="FillAndExpand" HeightRequest="1"  Color="Gray"/>

            
            <Grid Grid.Row="2" RowDefinitions="*,auto,*" HorizontalOptions="Center" VerticalOptions="Center">
                <Label Grid.Row="0" x:Name="lbPostContent" FontSize="28" Margin="10"></Label>
                <BoxView Grid.Row="1" HorizontalOptions="FillAndExpand" HeightRequest="1" Color="Gray"/>
                <Grid ColumnDefinitions="Auto,*" Grid.Row="2" HorizontalOptions="Center" Margin="10" VerticalOptions="Center">
                    <Button Grid.Column="0" x:Name="btnLike" Clicked="BtnLike_OnClicked" Style="{x:StaticResource GoogleFont }" BackgroundColor="Transparent" WidthRequest="130" CornerRadius="18" FontAttributes="Bold" TextColor="#776CE6" BorderColor="#776CE6" Margin="0,0,10,0" HeightRequest="50" BorderWidth="1"/>
                    <Button Grid.Column="1" x:Name="btnComments" Clicked="BtnComments_OnClicked" Text="{x:Static icon:IconFont.Comment}" Style="{x:StaticResource GoogleFont }" BackgroundColor="Transparent" WidthRequest="130" CornerRadius="18" FontAttributes="Bold" TextColor="#776CE6" BorderColor="#776CE6" Margin="0,0,10,0" HeightRequest="50" BorderWidth="1"/>
                </Grid>
            </Grid>
                
            
                
        </Grid>
          
    </ScrollView>


</ContentPage>