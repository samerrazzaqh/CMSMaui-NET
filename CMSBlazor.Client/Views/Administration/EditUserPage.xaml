<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:icon="clr-namespace:CMSBlazor.Client.Utilities"
             BackgroundColor="{AppThemeBinding Dark='#212121',Light='#F5F5F5'}"
             x:Class="CMSBlazor.Client.Views.Administration.EditUserPage"
             Title="Edite User">
    
    
    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="{AppThemeBinding Dark='#212121',Light='#F5F5F5'}"
                                   StatusBarStyle="Default"/>
    </ContentPage.Behaviors>
    
    <NavigationPage.TitleView>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label Text="Edite User" Grid.Column="0"  FontSize="18" VerticalOptions="Center" HorizontalOptions="Start"></Label>

            <StackLayout Grid.Column="1" HorizontalOptions="EndAndExpand" Orientation="Horizontal" Margin="0,5,5,5">
                <Button HorizontalOptions="End" Clicked="BtnClose_OnClicked" Text="{x:Static icon:IconFont.Close}" Style="{x:StaticResource GoogleFont }" TextColor="#776CE6" BackgroundColor="Transparent" BorderWidth="1" BorderColor="Transparent" x:Name="btnClose"/>
            </StackLayout>
        </Grid>
    </NavigationPage.TitleView>
    
    <!-- ======================== -->
    
    
     <ScrollView>
        <StackLayout>
            <Border HeightRequest="60" BackgroundColor="#776CE6" StrokeThickness="0" Margin="10,10" StrokeShape="RoundRectangle 10" Stroke= "#776CE6">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer x:Name="borProfile"/>
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="auto" ColumnSpacing="10" HorizontalOptions="Center">
                    <Label Grid.Column="0" FontAttributes="Bold" x:Name="lbEmail" FontSize="25"  HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>
            </Border>
            
            <Border HorizontalOptions="Fill" Margin="10" BackgroundColor="Transparent" VerticalOptions="Fill" StrokeShape= "RoundRectangle 10" StrokeThickness="0.5" Stroke= "{AppThemeBinding Dark=White,Light=Black}">
                <StackLayout>
                    <Label  FontAttributes="Bold" Margin="0,20" TextDecorations="Underline" FontSize="20" Text="User Claims" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <CollectionView   x:Name="claimsList" Margin="20" BackgroundColor="Transparent">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="20">
                            </LinearItemsLayout>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <ContentView>
                                    <Grid ColumnDefinitions="auto" Padding="10,0,10,0" ColumnSpacing="10">
                                        <Label Grid.Column="0" FontSize="18" FontAttributes="Bold" Text="{Binding }" VerticalOptions="Start" HorizontalOptions="Start"/>
                                    </Grid>
                                </ContentView>
                        
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Button x:Name="popManageClaims"  Clicked="PopManageClaims_OnClicked"  WidthRequest="150" FontSize="18" CornerRadius="10" Margin="20" Text="Manage Claims" HeightRequest="50" TextColor="White" BackgroundColor="#776CE6" VerticalOptions="Start" HorizontalOptions="Start"></Button>
                </StackLayout>
            </Border>
            
            
            
            <Border HorizontalOptions="Fill" Margin="10" BackgroundColor="Transparent" VerticalOptions="Fill" StrokeShape= "RoundRectangle 10" StrokeThickness="0.5" Stroke= "{AppThemeBinding Dark=White,Light=Black}">
                <StackLayout>
                    <Label  FontAttributes="Bold" Margin="0,20" TextDecorations="Underline" FontSize="20" Text="User Roles" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <CollectionView   x:Name="RolesList" Margin="20" BackgroundColor="Transparent">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="20">
                            </LinearItemsLayout>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <ContentView>
                                    <Grid ColumnDefinitions="auto" Padding="10,0,10,0" ColumnSpacing="10">
                                        <Label Grid.Column="0" FontSize="18" FontAttributes="Bold" Text="{Binding }" VerticalOptions="Start" HorizontalOptions="Start"/>
                                    </Grid>
                                </ContentView>
                        
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Button x:Name="btManageRole" Clicked="BtManageRole_OnClicked" WidthRequest="150" FontSize="18" CornerRadius="10" Margin="20" Text="Manage Role" HeightRequest="50" TextColor="White" BackgroundColor="#776CE6" VerticalOptions="Start" HorizontalOptions="Start"></Button>
                </StackLayout>
            </Border>
            
            <StackLayout>
                <Grid ColumnDefinitions="50,*" Margin="20" ColumnSpacing="10">
                    <CheckBox Grid.Column="0" x:Name="chBlock" Color="#776CE6" VerticalOptions="Start" HorizontalOptions="Start"></CheckBox>
                    <Label Grid.Column="1" FontSize="18" FontAttributes="Bold" x:Name="lbBlock" VerticalOptions="Start" HorizontalOptions="Start"/>
                </Grid>
                <Button x:Name="btSubmit" Clicked="BtSubmit_OnClicked"  WidthRequest="150" FontSize="18" CornerRadius="10" Margin="20" Text="Submit" HeightRequest="50" TextColor="White" BackgroundColor="#776CE6" VerticalOptions="Start" HorizontalOptions="Start"></Button>
            </StackLayout>
            
        </StackLayout>
   </ScrollView>
    
  
</ContentPage>